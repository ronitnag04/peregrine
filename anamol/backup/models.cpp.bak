// main entry
void get_throughput(vector<Instr> instr_trace, int window_size) {
  if (instr_trace.empty()) return;

  // clear any previous results
  for (auto& v : PER_RES_THR_VECS) v.clear();

  size_t num_windows = (instr_trace.size() + window_size - 1) / window_size;

  // For each resource, for each param combo, we build one ThrVec and append
  for (size_t res_idx = 0; res_idx < (size_t)Resource::COUNT; ++res_idx) {
    const auto& res_meta = RESOURCE_TABLE[res_idx];
    auto& thr_vecs_for_res = PER_RES_THR_VECS[res_idx];

    // iterate parameter sweep for this resource
    for (const auto& params : res_meta.param_sweep) {
      ThrVec tv;
      tv.double_params = (params.size() > 1);
      tv.p0 = params.size() > 0 ? params[0] : 0;
      tv.p1 = params.size() > 1 ? params[1] : 0;
      tv.data.reserve(num_windows);

      // evaluate throughput on each window for this (res, params)
      for (size_t win_idx = 0; win_idx < num_windows; ++win_idx) {
        size_t start_idx = win_idx * window_size;
        size_t end_idx = std::min(start_idx + window_size, instr_trace.size());

        vector<Instr> window(instr_trace.begin() + start_idx,
                             instr_trace.begin() + end_idx);

        double thr = res_meta.get_thr(window, params);
        tv.data.push_back(thr);
      }

      thr_vecs_for_res.push_back(std::move(tv));
    }
  }
}

}  // namespace analytical